PORT=8080
BUCKET_NAME=your-gcs-bucket-name
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Optional origin allowlist (comma-separated). Leave empty to allow all origins.
CORS_ORIGINS=http://localhost:3000

# Optional API key protection for uploads.
UPLOAD_API_KEY=

# true -> make uploaded files public and return public URL
# false -> keep private and return signed URL (7 days)
MAKE_PUBLIC=false

# Max upload size in bytes
MAX_UPLOAD_BYTES=60000000
